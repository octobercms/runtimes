{
  "name": "October CMS Runtime Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "..",
    "args": {
      "DEV_IMAGE": "ghcr.io/octobercms/runtime-dev:php85"
    }
  },
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "customizations": {
    "codespaces": {
      "openFiles": []
    }
  },
  "forwardPorts": [80],
  "portsAttributes": {
    "80": {
      "label": "October CMS",
      "onAutoForward": "openPreview",
      "protocol": "https"
    }
  },
  "postCreateCommand": "bash /usr/local/bin/devcontainer-post-create.sh",
  "postStartCommand": "bash /usr/local/bin/devcontainer-post-start.sh"
}
